#include <Servo.h>

Servo servoRight;
Servo servoLeft;

//Motorconnections
constexpr int pinFeedbackLeft = 7;
constexpr int pinFeedbackRight = 8;
constexpr int pinControlLeft = 5;
constexpr int pinControlRight = 6;

int pos = 0;

unsigned long highRight = 0, highLeft = 0;
unsigned long lowRight = 0, lowLeft = 0;
char keyCommand;
double dutyCycleRight = 0.0, dutyCycleLeft = 0.0;
unsigned long cycleTimeRight, cycleTimeLeft;
double totalCycle = 1098.901;
double thetaRight = 0.0, thetaLeft = 0.0;
double thetaRightP = 0.0, thetaLeftP = 0.0;
int turnsRight = -1, turnsLeft = 0;

void calculateThetaRight();
void calculateThetaLeft();

void setup(){
  Serial.begin(9600);
  pinMode(pinFeedbackRight, INPUT);
  pinMode(pinFeedbackLeft, INPUT);
  } 

void loop(){
  if (Serial.available() > 0){
    keyCommand = Serial.read();
    
    switch(keyCommand){
      case 'f': 
        servoRight.attach(pinControlRight);
        servoLeft.attach(pinControlLeft);
          servoRight.write(89);
          servoLeft.write(98);
          delay(500);
          servoRight.detach();
          servoLeft.detach();
          calculateThetaRight();
          calculateThetaLeft();
          if ((thetaRight < 90) && (thetaRightP > 270.0)) turnsRight--;
            else if ((thetaRightP < 90) && (thetaRight > 270)) turnsRight++;
          if ((thetaLeft < 90) && (thetaLeftP > 270.0)) turnsLeft++;
            else if ((thetaLeftP < 90) && (thetaLeft > 270)) turnsLeft--;
          Serial.print("thetaRight: ");
          Serial.print(thetaRight);
          Serial.print(", thetaLeft: ");
          Serial.print(thetaLeft);
          Serial.print(", turnsRight: ");
          Serial.print(turnsRight);
          Serial.print(", turnsLeft: ");
          Serial.println(turnsLeft);
        break;
      case 'b': 
        servoRight.attach(pinControlRight);
        servoLeft.attach(pinControlLeft);
        servoRight.write(98);
        servoLeft.write(89);
        delay(500);
        servoRight.detach();
        servoLeft.detach();
        break;
      case 's': 
        servoRight.attach(pinControlRight);
        servoLeft.attach(pinControlLeft);
        servoRight.write(94);
        servoLeft.write(94);
        delay(500);
        servoRight.detach();
        servoLeft.detach();
        break;
      default: break;
    }   
  }
}

void calculateThetaRight(){
  highRight = pulseIn(pinFeedbackRight, HIGH);
  lowRight = pulseIn(pinFeedbackRight, LOW);
  cycleTimeRight = highRight + lowRight;
  dutyCycleRight = (float)(highRight * 100.0) / (float)cycleTimeRight;
  thetaRightP = thetaRight;
  thetaRight = (360.0 - 1.0) - ((dutyCycleRight - 2.9) * 360.0) / ( 97.1 - 2.9 + 1);
}

void calculateThetaLeft(){
  highLeft = pulseIn(pinFeedbackLeft, HIGH);
  lowLeft = pulseIn(pinFeedbackLeft, LOW);
  cycleTimeLeft = highLeft + lowLeft;  
  dutyCycleLeft = (float)(highLeft * 100.0) / (float)cycleTimeLeft;
  thetaLeftP = thetaLeft;
  thetaLeft = (360.0 - 1.0) - ((dutyCycleLeft - 2.9) * 360.0) / ( 97.1 - 2.9 + 1);
}
